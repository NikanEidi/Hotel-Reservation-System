+    @FXML
+    private HBox summaryRoomServiceRow;
+
+    @FXML
+    private Label summaryRoomServiceLabel;
+
+    @FXML
+    private Label summaryRoomServicePrice;
+
+    // FXML Elements - Price Breakdown
+    @FXML
+    private Label pricingTypeLabel;
+
+    @FXML
+    private Label subtotalLabel;
+
+    @FXML
+    private Label taxLabel;
+
+    @FXML
+    private HBox summaryDiscountRow;
+
+    @FXML
+    private Label summaryDiscount;
+
+    @FXML
+    private Label totalLabel;
+
+    // FXML Elements - Loyalty Info
+    @FXML
+    private Label loyaltyStatusLabel;
+
+    @FXML
+    private Label loyaltyNumberLabel;
+
+    @FXML
+    private VBox loyaltyInfoBox;
+
+    // Reference to main controller
+    private UIController mainController;
+
+    private DateTimeFormatter dateFormatter = DateTimeFormatter.ofPattern("MMM dd, yyyy");
+
+    /**
+     * Set the parent controller and load summary data
+     */
+    public void setMainController(UIController controller) {
+        this.mainController = controller;
+        loadSummaryData();
+    }
+
+    private void loadSummaryData() {
+        UIController.BookingData data = mainController.getBookingData();
+        if (data == null) return;
+
+        // Guest Information
+        summaryGuestName.setText(data.guestName != null ? data.guestName : "Guest");
+
+        if (data.checkIn != null && data.checkOut != null) {
+            summaryCheckIn.setText(data.checkIn.format(dateFormatter) + " (3:00 PM)");
+            summaryCheckOut.setText(data.checkOut.format(dateFormatter) + " (11:00 AM)");
+            long nights = ChronoUnit.DAYS.between(data.checkIn, data.checkOut);
+            summaryNights.setText(nights + " nights");
+        }
+
+        summaryGuests.setText(data.adults + " Adults, " + data.children + " Children");
+
+        // Room Information
+        String roomTypeName = getRoomTypeName(data.selectedRoomType);
+        summaryRoomType.setText(roomTypeName);
+        summaryRoomQuantity.setText("x" + data.roomQuantity);
+        summaryRoomPrice.setText("$" + mainController.getRoomPrice());
+
+        // Add-ons (show only if selected)
+        setupAddOnsDisplay(data);
+
+        // Price Breakdown with Dynamic Pricing
+        pricingTypeLabel.setText(mainController.getPricingTypeDescription());
+        subtotalLabel.setText("$" + mainController.getSubtotal());
+        taxLabel.setText("$" + mainController.getTax());
+
+        // Loyalty Discount (if any points redeemed)
+        if (data.loyaltyPointsToRedeem > 0) {
+            BigDecimal discount = calculateLoyaltyDiscount(data);
+            summaryDiscountRow.setVisible(true);
+            summaryDiscountRow.setManaged(true);
+            summaryDiscount.setText("-$" + discount);
+        } else {
+            summaryDiscountRow.setVisible(false);
+            summaryDiscountRow.setManaged(false);
+        }
+
+        totalLabel.setText("$" + mainController.getTotal());
+
+        // Loyalty Information
+        if (data.enrollLoyalty) {
+            loyaltyStatusLabel.setText("✓ Enrolled");
+            loyaltyNumberLabel.setText(generateLoyaltyNumber());
+            loyaltyInfoBox.setVisible(true);
+            loyaltyInfoBox.setManaged(true);
+        } else {
+            loyaltyStatusLabel.setText("Not Enrolled");
+            loyaltyInfoBox.setVisible(false);
+            loyaltyInfoBox.setManaged(false);
+        }
+    }
+
+    private String getRoomTypeName(UIController.RoomType type) {
+        switch (type) {
+            case SINGLE: return "Single Room (1 Queen Bed)";
+            case DOUBLE: return "Double Room (2 Queen Beds)";
+            case DELUXE: return "Deluxe Room (King Bed + City View)";
+            case PENTHOUSE: return "Penthouse Suite (Panoramic View + Jacuzzi)";
+            default: return "Standard Room";
+        }
+    }
+
+    private void setupAddOnsDisplay(UIController.BookingData data) {
+        // Wi-Fi
+        if (data.hasWifi && data.wifiQuantity > 0) {
+            summaryWifiRow.setVisible(true);
+            summaryWifiRow.setManaged(true);
+            summaryWifiLabel.setText("Wi-Fi (" + data.wifiQuantity + " devices, " + data.nights + " nights)");
+            summaryWifiPrice.setText("$" + calculateWifiPrice(data));
+        } else {
+            summaryWifiRow.setVisible(false);
+            summaryWifiRow.setManaged(false);
+        }
+
+        // Breakfast
+        if (data.hasBreakfast && data.breakfastQuantity > 0) {
+            summaryBreakfastRow.setVisible(true);
+            summaryBreakfastRow.setManaged(true);
+            summaryBreakfastLabel.setText("Breakfast (" + data.breakfastQuantity + " persons, " + data.nights + " days)");
+            summaryBreakfastPrice.setText("$" + calculateBreakfastPrice(data));
+        } else {
+            summaryBreakfastRow.setVisible(false);
+            summaryBreakfastRow.setManaged(false);
+        }
+
+        // Parking
+        if (data.hasParking && data.parkingQuantity > 0) {
+            summaryParkingRow.setVisible(true);
+            summaryParkingRow.setManaged(true);
+            summaryParkingLabel.setText("Parking (" + data.parkingQuantity + " cars, " + data.nights + " nights)");
+            summaryParkingPrice.setText("$" + calculateParkingPrice(data));
+        } else {
+            summaryParkingRow.setVisible(false);
+            summaryParkingRow.setManaged(false);
+        }
+
+        // Spa
+        if (data.hasSpa && data.spaQuantity > 0) {
+            summarySpaRow.setVisible(true);
+            summarySpaRow.setManaged(true);
+            summarySpaLabel.setText("Spa (" + data.spaQuantity + " sessions)");
+            summarySpaPrice.setText("$" + calculateSpaPrice(data));
+        } else {
+            summarySpaRow.setVisible(false);
+            summarySpaRow.setManaged(false);
+        }
+
+        // Shuttle (if available)
+        // Room Service (if available)
+    }
+
+    private BigDecimal calculateWifiPrice(UIController.BookingData data) {
+        return BigDecimal.valueOf(10)
+                .multiply(BigDecimal.valueOf(data.nights))
+                .multiply(BigDecimal.valueOf(data.wifiQuantity));
+    }
+
+    private BigDecimal calculateBreakfastPrice(UIController.BookingData data) {
+        return BigDecimal.valueOf(15)
+                .multiply(BigDecimal.valueOf(data.nights))
+                .multiply(BigDecimal.valueOf(data.breakfastQuantity));
+    }
+
+    private BigDecimal calculateParkingPrice(UIController.BookingData data) {
+        return BigDecimal.valueOf(20)
+                .multiply(BigDecimal.valueOf(data.nights))
+                .multiply(BigDecimal.valueOf(data.parkingQuantity));
+    }
+
+    private BigDecimal calculateSpaPrice(UIController.BookingData data) {
+        return BigDecimal.valueOf(50)
+                .multiply(BigDecimal.valueOf(data.spaQuantity));
+    }
+
+    private BigDecimal calculateLoyaltyDiscount(UIController.BookingData data) {
+        // 100 points = $10 discount
+        return BigDecimal.valueOf(data.loyaltyPointsToRedeem / 100)
+                .multiply(BigDecimal.TEN);
+    }
+
+    private String generateLoyaltyNumber() {
+        return "LTY-" + System.currentTimeMillis();
+    }
+
+    @FXML
+    public void goToConfirmation(ActionEvent event) throws IOException {
+        mainController.goToConfirmation(event);
+    }
+
+    @FXML
+    public void goToLoyalty(ActionEvent event) throws IOException {
+        mainController.goToLoyalty(event);
+    }
