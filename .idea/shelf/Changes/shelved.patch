+package com.seneca.hotelreservation_system.controller;
+
+import javafx.event.ActionEvent;
+import javafx.fxml.FXML;
+import javafx.scene.control.*;
+import javafx.scene.layout.HBox;
+import javafx.scene.layout.VBox;
+import java.io.IOException;
+import java.math.BigDecimal;
+
+public class LoyaltyController {
+
+    // FXML Elements - Enrollment
+    @FXML
+    private ToggleGroup enrollGroup;
+
+    @FXML
+    private RadioButton enrollYesBtn;
+
+    @FXML
+    private RadioButton enrollNoBtn;
+
+    @FXML
+    private Label loyaltyNumberLabel;
+
+    @FXML
+    private VBox loyaltyNumberBox;
+
+    // FXML Elements - Points Calculator
+    @FXML
+    private Label bookingTotalLabel;
+
+    @FXML
+    private Label pointsToEarnLabel;
+
+    @FXML
+    private TextField pointsToRedeemField;
+
+    @FXML
+    private Label discountAmountLabel;
+
+    @FXML
+    private Label newTotalLabel;
+
+    @FXML
+    private Button applyPointsBtn;
+
+    // FXML Elements - Benefits Section
+    @FXML
+    private VBox benefitsBox;
+
+    @FXML
+    private VBox calculatorBox;
+
+    // Reference to main controller
+    private UIController mainController;
+
+    // Loyalty constants
+    private static final int POINTS_PER_10_DOLLARS = 10;  // 10 points per $10 = 1 point per $1
+    private static final int POINTS_FOR_10_DOLLAR_DISCOUNT = 100;  // 100 points = $10 discount
+    private static final BigDecimal MAX_DISCOUNT_PERCENT = new BigDecimal("0.30");  // Max 30% discount
+
+    private BigDecimal originalTotal;
+    private int earnedPoints;
+    private int appliedPoints = 0;
+    private BigDecimal appliedDiscount = BigDecimal.ZERO;
+
+    /**
+     * Set the parent controller to access booking data
+     */
+    public void setMainController(UIController controller) {
+        this.mainController = controller;
+        loadBookingData();
+        calculatePoints();
+        setupEnrollmentDisplay();
+        setupPointsRedeemField();
+    }
+
+    private void loadBookingData() {
+        UIController.BookingData data = mainController.getBookingData();
+        if (data != null) {
+            originalTotal = data.total != null ? data.total : BigDecimal.ZERO;
+            bookingTotalLabel.setText("$" + originalTotal.toString());
+
+            // Load existing loyalty choice if any
+            enrollYesBtn.setSelected(data.enrollLoyalty);
+            enrollNoBtn.setSelected(!data.enrollLoyalty);
+
+            if (data.loyaltyPointsToRedeem > 0) {
+                pointsToRedeemField.setText(String.valueOf(data.loyaltyPointsToRedeem));
+                applyPoints();
+            }
+        }
+    }
+
+    private void calculatePoints() {
+        // Earn 10 points per $1 spent (or 1 point per $0.10)
+        // Actually: 1 point per $1 spent (since 10 points per $10)
+        earnedPoints = originalTotal.intValue();  // $425 = 425 points
+        pointsToEarnLabel.setText(String.valueOf(earnedPoints));
+    }
+
+    private void setupEnrollmentDisplay() {
+        // Generate unique loyalty number
+        String loyaltyNumber = "LTY-" + System.currentTimeMillis();
+        loyaltyNumberLabel.setText(loyaltyNumber);
+
+        // Show/hide loyalty number based on enrollment choice
+        loyaltyNumberBox.setVisible(enrollYesBtn.isSelected());
+        loyaltyNumberBox.setManaged(enrollYesBtn.isSelected());
+
+        enrollGroup.selectedToggleProperty().addListener((obs, oldVal, newVal) -> {
+            boolean isEnrolled = newVal == enrollYesBtn;
+            loyaltyNumberBox.setVisible(isEnrolled);
+            loyaltyNumberBox.setManaged(isEnrolled);
+        });
+    }
+
+    private void setupPointsRedeemField() {
+        pointsToRedeemField.textProperty().addListener((obs, oldVal, newVal) -> {
+            validatePointsInput(newVal);
+        });
+
+        applyPointsBtn.setOnAction(e -> applyPoints());
+    }
+
+    private void validatePointsInput(String input) {
+        try {
+            if (input == null || input.isEmpty()) {
+                return;
+            }
+
+            int points = Integer.parseInt(input);
+            int maxPoints = earnedPoints;
+
+            if (points < 0) {
+                pointsToRedeemField.setText("0");
+            } else if (points > maxPoints) {
+                pointsToRedeemField.setText(String.valueOf(maxPoints));
+                showAlert("Maximum Points", "You can only redeem up to " + maxPoints + " points.");
+            }
+        } catch (NumberFormatException e) {
+            pointsToRedeemField.setText("0");
+        }
+    }
+
+    private void applyPoints() {
+        try {
+            int points = Integer.parseInt(pointsToRedeemField.getText().trim());
+
+            // Calculate discount: 100 points = $10 discount
+            BigDecimal discountFromPoints = BigDecimal.valueOf(points / POINTS_FOR_10_DOLLAR_DISCOUNT)
+                    .multiply(BigDecimal.TEN);
+
+            // Apply maximum discount cap (30% of total)
+            BigDecimal maxDiscount = originalTotal.multiply(MAX_DISCOUNT_PERCENT);
+
+            if (discountFromPoints.compareTo(maxDiscount) > 0) {
+                discountFromPoints = maxDiscount;
+                points = maxDiscount.multiply(BigDecimal.valueOf(POINTS_FOR_10_DOLLAR_DISCOUNT))
+                        .divide(BigDecimal.TEN, 0, BigDecimal.ROUND_DOWN).intValue();
+                pointsToRedeemField.setText(String.valueOf(points));
+                showAlert("Discount Cap", "Maximum discount of 30% applied.");
+            }
+
+            appliedPoints = points;
+            appliedDiscount = discountFromPoints;
+
+            BigDecimal newTotal = originalTotal.subtract(appliedDiscount);
+            if (newTotal.compareTo(BigDecimal.ZERO) < 0) {
+                newTotal = BigDecimal.ZERO;
+            }
+
+            discountAmountLabel.setText("-$" + appliedDiscount.toString());
+            newTotalLabel.setText("$" + newTotal.toString());
+
+        } catch (NumberFormatException e) {
+            appliedPoints = 0;
+            appliedDiscount = BigDecimal.ZERO;
+            discountAmountLabel.setText("-$0");
+            newTotalLabel.setText("$" + originalTotal.toString());
+        }
+    }
+
+    @FXML
+    public void goToSummary(ActionEvent event) throws IOException {
+        // Save loyalty data to main controller
+        boolean enrollLoyalty = enrollYesBtn.isSelected();
+        int pointsToRedeem = 0;
+
+        try {
+            pointsToRedeem = Integer.parseInt(pointsToRedeemField.getText().trim());
+        } catch (NumberFormatException e) {
+            pointsToRedeem = 0;
+        }
+
+        mainController.setLoyaltyData(enrollLoyalty, pointsToRedeem);
+
+        // Update total with discount
+        UIController.BookingData data = mainController.getBookingData();
+        if (data != null && appliedDiscount.compareTo(BigDecimal.ZERO) > 0) {
+            data.total = originalTotal.subtract(appliedDiscount);
+        }
+
+        // Navigate to next screen
+        mainController.goToSummary(event);
+    }
+
+    @FXML
+    public void goToAddOns(ActionEvent event) throws IOException {
+        mainController.goToAddOns(event);
+    }
+
+    private void showAlert(String title, String message) {
+        Alert alert = new Alert(Alert.AlertType.INFORMATION);
+        alert.setTitle(title);
+        alert.setHeaderText(null);
+        alert.setContentText(message);
+        alert.showAndWait();
+    }
+}
