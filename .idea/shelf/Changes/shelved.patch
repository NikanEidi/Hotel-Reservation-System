+    public enum RoomType {
+        SINGLE(89, 2), DOUBLE(129, 4), DELUXE(199, 2), PENTHOUSE(349, 2);
+        private final int basePrice;
+        private final int maxOccupancy;
+        RoomType(int basePrice, int maxOccupancy) {
+            this.basePrice = basePrice;
