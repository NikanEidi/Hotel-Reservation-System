+        breakfastSpinner.disableProperty().bind(breakfastCheck.selectedProperty().not());
+
+        // Parking Spinner (quantity = number of cars)
+        parkingSpinner.setValueFactory(new SpinnerValueFactory.IntegerSpinnerValueFactory(0, 3, 0));
+        parkingSpinner.setEditable(true);
+        parkingSpinner.disableProperty().bind(parkingCheck.selectedProperty().not());
+
+        // Spa Spinner (quantity = number of sessions)
+        spaSpinner.setValueFactory(new SpinnerValueFactory.IntegerSpinnerValueFactory(0, 10, 0));
+        spaSpinner.setEditable(true);
+        spaSpinner.disableProperty().bind(spaCheck.selectedProperty().not());
+
+        // Shuttle Spinner (quantity = number of trips)
+        shuttleSpinner.setValueFactory(new SpinnerValueFactory.IntegerSpinnerValueFactory(0, 4, 0));
+        shuttleSpinner.setEditable(true);
+        shuttleSpinner.disableProperty().bind(shuttleCheck.selectedProperty().not());
+
+        // Room Service Spinner (quantity = number of days)
+        roomServiceSpinner.setValueFactory(new SpinnerValueFactory.IntegerSpinnerValueFactory(0, nights, 0));
+        roomServiceSpinner.setEditable(true);
+        roomServiceSpinner.disableProperty().bind(roomServiceCheck.selectedProperty().not());
+
+        // Add listeners to spinners to update total
+        wifiSpinner.valueProperty().addListener((obs, oldVal, newVal) -> updateTotalDisplay());
+        breakfastSpinner.valueProperty().addListener((obs, oldVal, newVal) -> updateTotalDisplay());
+        parkingSpinner.valueProperty().addListener((obs, oldVal, newVal) -> updateTotalDisplay());
+        spaSpinner.valueProperty().addListener((obs, oldVal, newVal) -> updateTotalDisplay());
+        shuttleSpinner.valueProperty().addListener((obs, oldVal, newVal) -> updateTotalDisplay());
+        roomServiceSpinner.valueProperty().addListener((obs, oldVal, newVal) -> updateTotalDisplay());
+    }
+
+    private void setupCheckboxListeners() {
+        wifiCheck.selectedProperty().addListener((obs, oldVal, newVal) -> {
+            if (!newVal) wifiSpinner.getValueFactory().setValue(0);
+            updateTotalDisplay();
+        });
+
+        breakfastCheck.selectedProperty().addListener((obs, oldVal, newVal) -> {
+            if (!newVal) breakfastSpinner.getValueFactory().setValue(0);
+            updateTotalDisplay();
+        });
+
+        parkingCheck.selectedProperty().addListener((obs, oldVal, newVal) -> {
+            if (!newVal) parkingSpinner.getValueFactory().setValue(0);
+            updateTotalDisplay();
+        });
+
+        spaCheck.selectedProperty().addListener((obs, oldVal, newVal) -> {
+            if (!newVal) spaSpinner.getValueFactory().setValue(0);
+            updateTotalDisplay();
+        });
+
+        shuttleCheck.selectedProperty().addListener((obs, oldVal, newVal) -> {
+            if (!newVal) shuttleSpinner.getValueFactory().setValue(0);
+            updateTotalDisplay();
+        });
+
+        roomServiceCheck.selectedProperty().addListener((obs, oldVal, newVal) -> {
+            if (!newVal) roomServiceSpinner.getValueFactory().setValue(0);
+            updateTotalDisplay();
+        });
+    }
+
+    private void updateTotalDisplay() {
+        BigDecimal total = calculateTotal();
+        addonsTotalLabel.setText("$" + total.toString());
+    }
+
+    private BigDecimal calculateTotal() {
+        BigDecimal total = BigDecimal.ZERO;
+
+        // Wi-Fi
+        if (wifiCheck.isSelected() && wifiSpinner.getValue() > 0) {
+            total = total.add(WIFI_PRICE_PER_NIGHT
+                    .multiply(BigDecimal.valueOf(nights))
+                    .multiply(BigDecimal.valueOf(wifiSpinner.getValue())));
+        }
+
+        // Breakfast
+        if (breakfastCheck.isSelected() && breakfastSpinner.getValue() > 0) {
+            total = total.add(BREAKFAST_PRICE_PER_PERSON_PER_DAY
+                    .multiply(BigDecimal.valueOf(nights))
+                    .multiply(BigDecimal.valueOf(breakfastSpinner.getValue())));
+        }
+
+        // Parking
+        if (parkingCheck.isSelected() && parkingSpinner.getValue() > 0) {
+            total = total.add(PARKING_PRICE_PER_DAY
+                    .multiply(BigDecimal.valueOf(nights))
+                    .multiply(BigDecimal.valueOf(parkingSpinner.getValue())));
+        }
+
+        // Spa
+        if (spaCheck.isSelected() && spaSpinner.getValue() > 0) {
+            total = total.add(SPA_PRICE_PER_SESSION
+                    .multiply(BigDecimal.valueOf(spaSpinner.getValue())));
+        }
+
+        // Shuttle
+        if (shuttleCheck.isSelected() && shuttleSpinner.getValue() > 0) {
+            total = total.add(SHUTTLE_PRICE_PER_TRIP
+                    .multiply(BigDecimal.valueOf(shuttleSpinner.getValue())));
+        }
+
+        // Room Service
+        if (roomServiceCheck.isSelected() && roomServiceSpinner.getValue() > 0) {
+            total = total.add(ROOM_SERVICE_PRICE_PER_DAY
+                    .multiply(BigDecimal.valueOf(roomServiceSpinner.getValue())));
+        }
+
+        return total;
+    }
+
+    @FXML
+    public void goToLoyalty(ActionEvent event) throws IOException {
+        // Save add-ons data to main controller
+        mainController.setAddonsData(
+                wifiCheck.isSelected(),
+                breakfastCheck.isSelected(),
+                parkingCheck.isSelected(),
+                spaCheck.isSelected(),
+                wifiSpinner.getValue(),
+                breakfastSpinner.getValue(),
+                parkingSpinner.getValue(),
+                spaSpinner.getValue()
+        );
+
+        // Navigate to next screen
+        mainController.goToLoyalty(event);
+    }
+
+    @FXML
+    public void goToRoomSelection(ActionEvent event) throws IOException {
+        mainController.goToRoomSelection(event);
+    }
