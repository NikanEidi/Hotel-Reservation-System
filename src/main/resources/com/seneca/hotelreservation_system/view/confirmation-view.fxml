<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.UIController">

    <VBox alignment="CENTER" spacing="50.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="15.0">
            <Label text="BOOKING SUCCESSFUL" style="-fx-text-fill: #10b981; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-letter-spacing: 5px;" />
            <Label text="Your reservation has been confirmed." style="-fx-text-fill: white; -fx-font-size: 20px; -fx-letter-spacing: 1px;" />
        </VBox>

        <VBox alignment="CENTER" maxWidth="600.0" spacing="25.0" style="-fx-background-color: #0a0a0a; -fx-padding: 40; -fx-border-color: #10b981; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10;">
            <effect><DropShadow color="#10b98133" radius="25.0" /></effect>

            <Label text="Reservation ID:" style="-fx-text-fill: #a8a29e; -fx-font-size: 16px; -fx-text-transform: uppercase;" />
            <Label text="RES-98432-XYZ" style="-fx-text-fill: #d4af37; -fx-font-size: 32px; -fx-font-weight: bold; -fx-letter-spacing: 3px;" />

            <Region prefHeight="10.0" style="-fx-background-color: #44403c;" />

            <Label text="Please proceed to the reception desk to complete your payment." style="-fx-text-fill: #10b981; -fx-font-size: 18px; -fx-font-weight: bold; -fx-wrap-text: true; -fx-text-alignment: center;" />
        </VBox>

        <Button onAction="#goToWelcome" text="RETURN TO HOME" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-pref-width: 250; -fx-pref-height: 50; -fx-font-weight: bold; -fx-cursor: hand;" />

    </VBox>

</AnchorPane>
