<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.ConfirmationController">

    <VBox alignment="CENTER" spacing="30" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Label text="BOOKING SUCCESSFUL" style="-fx-text-fill: #10b981; -fx-font-size: 42px; -fx-font-weight: bold;" />
        <Label text="Your reservation has been confirmed." style="-fx-text-fill: white; -fx-font-size: 18px;" />

        <VBox spacing="15" style="-fx-background-color: #0a0a0a; -fx-padding: 30; -fx-border-color: #10b981; -fx-border-width: 2; -fx-border-radius: 15;" maxWidth="500">

            <Label fx:id="bookingReferenceLabel" text="BK-XXXXXX" style="-fx-text-fill: #d4af37; -fx-font-size: 24px;" />

            <Label fx:id="loyaltyNumberLabel" text="" style="-fx-text-fill: #d4af37;" visible="false" managed="false" />

            <Label text="Please proceed to the reception desk to complete your payment." style="-fx-text-fill: #10b981; -fx-font-size: 16px; -fx-wrap-text: true;" />

        </VBox>

        <Button onAction="#goToWelcome" text="RETURN TO HOME" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-pref-width: 200; -fx-pref-height: 50;" />

    </VBox>

</AnchorPane>