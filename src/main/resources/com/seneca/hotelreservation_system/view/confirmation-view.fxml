<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.ConfirmationController">

    <VBox alignment="CENTER" spacing="30.0"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
          style="-fx-padding: 0 100;">

        <VBox alignment="CENTER" spacing="9.0">
            <Label text="RESERVATION COMPLETE"
                   style="-fx-text-fill: #22c55e; -fx-font-size: 11px; -fx-letter-spacing: 4px; -fx-font-weight: bold;" />
            <Label text="Booking Confirmed"
                   style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />
            <Label text="Your stay at Grand Plaza Hotel has been confirmed"
                   style="-fx-text-fill: #54483a; -fx-font-size: 14px;" />
        </VBox>

        <HBox alignment="CENTER" spacing="26.0" maxWidth="1060.0">

            <VBox spacing="0.0" prefWidth="460.0"
                  style="-fx-background-color: rgba(255,255,255,0.025);
                         -fx-border-color: rgba(34,197,94,0.28); -fx-border-width: 1.5;
                         -fx-background-radius: 14; -fx-border-radius: 14;">
                <effect><DropShadow color="#22c55e18" radius="28.0" /></effect>

                <VBox alignment="CENTER" spacing="7.0"
                      style="-fx-padding: 26 28;
                             -fx-border-color: rgba(34,197,94,0.15); -fx-border-width: 0 0 1 0;">
                    <Label text="BOOKING REFERENCE"
                           style="-fx-text-fill: #22c55e; -fx-font-size: 9px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />
                    <Label fx:id="bookingReferenceLabel" text="BK-00000000-0000"
                           style="-fx-text-fill: #c8a84b; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
                    <Label fx:id="confirmationDateLabel" text="--"
                           style="-fx-text-fill: #54483a; -fx-font-size: 12px;" />
                </VBox>

                <VBox spacing="0.0"
                      style="-fx-background-color: #0b0b14; -fx-background-radius: 0 0 14 14;">

                    <HBox spacing="10.0" style="-fx-padding: 12 22; -fx-border-color: rgba(200,168,75,0.06); -fx-border-width: 0 0 1 0;">
                        <Label text="Guest" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="guestNameLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 12 22; -fx-border-color: rgba(200,168,75,0.06); -fx-border-width: 0 0 1 0;">
                        <Label text="Email" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="emailLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 12 22; -fx-border-color: rgba(200,168,75,0.06); -fx-border-width: 0 0 1 0;">
                        <Label text="Check-In" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="checkInLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 12 22; -fx-border-color: rgba(200,168,75,0.06); -fx-border-width: 0 0 1 0;">
                        <Label text="Check-Out" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="checkOutLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 12 22; -fx-border-color: rgba(200,168,75,0.06); -fx-border-width: 0 0 1 0;">
                        <Label text="Nights" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="nightsLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 12 22; -fx-border-color: rgba(200,168,75,0.06); -fx-border-width: 0 0 1 0;">
                        <Label text="Room" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="roomTypeLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Label fx:id="roomQuantityLabel" text="" style="-fx-text-fill: #c8a84b; -fx-font-size: 12px;" />
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 14 22 18 22;">
                        <Label text="Total" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 86;" />
                        <Label fx:id="totalAmountLabel" text="$0.00"
                               style="-fx-text-fill: #c8a84b; -fx-font-size: 22px; -fx-font-weight: bold;" />
                    </HBox>

                </VBox>

            </VBox>

            <VBox spacing="16.0" prefWidth="360.0">

                <VBox spacing="10.0"
                      style="-fx-background-color: rgba(255,255,255,0.025);
                             -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                             -fx-background-radius: 12; -fx-border-radius: 12;
                             -fx-padding: 22 22;">
                    <Label text="NEXT STEPS"
                           style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 2px; -fx-font-weight: bold;" />
                    <Label fx:id="paymentInstructionLabel" text="Proceed to the front desk on arrival."
                           style="-fx-text-fill: white; -fx-font-size: 13px;" wrapText="true" />
                </VBox>

                <VBox fx:id="loyaltyInfoBox" spacing="8.0" visible="false" managed="false"
                      style="-fx-background-color: rgba(200,168,75,0.06);
                             -fx-border-color: rgba(200,168,75,0.30); -fx-border-width: 1;
                             -fx-background-radius: 10; -fx-border-radius: 10;
                             -fx-padding: 16 20;">
                    <Label text="LOYALTY ENROLLED"
                           style="-fx-text-fill: #c8a84b; -fx-font-size: 9px; -fx-letter-spacing: 2px; -fx-font-weight: bold;" />
                    <Label fx:id="loyaltyNumberLabel" text=""
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="INCLUDED SERVICES"
                           style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 2px; -fx-font-weight: bold;" />
                    <TextArea fx:id="addOnsDetailsArea"
                              prefHeight="90.0" editable="false" wrapText="true"
                              style="-fx-background-color: #0f0f1a; -fx-text-fill: #a8a29e;
                                     -fx-font-size: 12px;
                                     -fx-border-color: rgba(200,168,75,0.18); -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-padding: 10;" />
                </VBox>

                <HBox spacing="10.0">
                    <Button onAction="#printConfirmation" text="Print"
                            style="-fx-background-color: #0f0f1a; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-pref-height: 44; -fx-pref-width: 126;
                                   -fx-cursor: hand; -fx-background-radius: 8;
                                   -fx-border-color: rgba(200,168,75,0.18); -fx-border-width: 1; -fx-border-radius: 8;" />
                    <Button onAction="#emailConfirmation" text="Send Email"
                            style="-fx-background-color: #0f0f1a; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-pref-height: 44; -fx-pref-width: 126;
                                   -fx-cursor: hand; -fx-background-radius: 8;
                                   -fx-border-color: rgba(200,168,75,0.18); -fx-border-width: 1; -fx-border-radius: 8;" />
                </HBox>

                <Button onAction="#goToWelcome" text="RETURN TO HOME"
                        style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                               -fx-font-weight: bold; -fx-pref-height: 50; -fx-pref-width: 262;
                               -fx-cursor: hand; -fx-background-radius: 8;
                               -fx-font-size: 13px; -fx-letter-spacing: 1px;" />
            </VBox>

        </HBox>

    </VBox>

</AnchorPane>