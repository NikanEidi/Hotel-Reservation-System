<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #020617;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.UIController">

    <StackPane AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0"
               AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER"
              maxWidth="500.0"
              spacing="20.0"
              style="-fx-background-color: #0a0a0a; -fx-border-color: #d4af37; -fx-border-width: 2; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 40;">

            <padding>
                <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
            </padding>

            <effect>
                <DropShadow color="#d4af3733" radius="25.0" />
            </effect>

            <Label text="ADMIN LOGIN"
                   style="-fx-text-fill: #d4af37; -fx-font-size: 30px; -fx-font-weight: bold;" />

            <Label text="Please enter administrator credentials"
                   style="-fx-text-fill: #d6d3d1; -fx-font-size: 14px;" />

            <TextField fx:id="usernameField"
                       promptText="Username"
                       style="-fx-pref-width: 320; -fx-pref-height: 45;" />

            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           style="-fx-pref-width: 320; -fx-pref-height: 45;" />

            <Button text="LOGIN"
                    onAction="#handleAdminLogin"
                    style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-size: 15px; -fx-font-weight: bold; -fx-pref-width: 320; -fx-pref-height: 45; -fx-cursor: hand;" />

            <Button text="BACK"
                    onAction="#goToWelcome"
                    style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-pref-width: 320; -fx-pref-height: 45; -fx-cursor: hand;" />
        </VBox>
    </StackPane>
</AnchorPane>