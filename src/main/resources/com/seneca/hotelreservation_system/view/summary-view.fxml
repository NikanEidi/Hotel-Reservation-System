<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.SummaryController">

    <VBox alignment="CENTER" spacing="20" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Label text="BOOKING SUMMARY" style="-fx-text-fill: #d4af37; -fx-font-size: 42px; -fx-font-weight: bold;" />

        <VBox spacing="10" style="-fx-background-color: #0a0a0a; -fx-padding: 20; -fx-border-color: #d4af37; -fx-border-radius: 10;">
            <Label fx:id="summaryGuestName" text="Guest: Loading..." style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="summaryCheckIn" text="Check-in: " style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="summaryCheckOut" text="Check-out: " style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="summaryNights" text="Nights: " style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="summaryGuests" text="Guests: " style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="summaryRoomType" text="Room: " style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="summaryRoomPrice" text="Room Price: $0" style="-fx-text-fill: #d4af37; -fx-font-size: 18px;" />

            <Separator />

            <Label fx:id="pricingTypeLabel" text="Pricing: Standard" style="-fx-text-fill: #d4af37; -fx-font-size: 16px;" />
            <Label fx:id="subtotalLabel" text="Subtotal: $0" style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="taxLabel" text="Tax: $0" style="-fx-text-fill: white; -fx-font-size: 18px;" />
            <Label fx:id="totalLabel" text="TOTAL: $0" style="-fx-text-fill: #d4af37; -fx-font-size: 28px; -fx-font-weight: bold;" />
        </VBox>

        <HBox spacing="20">
            <Button onAction="#exportToCSV" text="📄 CSV" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 40; -fx-cursor: hand;" />
            <Button onAction="#exportToPDF" text="📑 PDF" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 40; -fx-cursor: hand;" />
            <Button onAction="#goToConfirmation" text="CONFIRM →" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 40; -fx-cursor: hand;" />
            <Button onAction="#goToLoyalty" text="← BACK" style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-pref-width: 120; -fx-pref-height: 40; -fx-cursor: hand;" />
        </HBox>

    </VBox>

</AnchorPane>