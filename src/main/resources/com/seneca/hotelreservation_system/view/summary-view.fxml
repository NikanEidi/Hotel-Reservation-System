<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.SummaryController">

    <VBox alignment="CENTER" spacing="20" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Label text="BOOKING SUMMARY" style="-fx-text-fill: #d4af37; -fx-font-size: 42px; -fx-font-weight: bold;" />

        <VBox spacing="10" style="-fx-background-color: #0a0a0a; -fx-padding: 20; -fx-border-color: #d4af37; -fx-border-radius: 10;">

            <!-- Guest Name -->
            <Label fx:id="summaryGuestName" text="Guest: " style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

            <!-- Stay Details -->
            <Label fx:id="summaryCheckIn" text="Check-in: " style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
            <Label fx:id="summaryCheckOut" text="Check-out: " style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
            <Label fx:id="summaryNights" text="Nights: " style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
            <Label fx:id="summaryGuests" text="Guests: " style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />

            <Separator />

            <!-- Room Details -->
            <Label fx:id="summaryRoomType" text="Room: " style="-fx-text-fill: #d4af37; -fx-font-size: 16px; -fx-font-weight: bold;" />
            <Label fx:id="summaryRoomPrice" text="Room Price: $0" style="-fx-text-fill: white; -fx-font-size: 14px;" />

            <Separator />

            <!-- ADD-ONS BREAKDOWN -->
            <Label text="ADD-ONS" style="-fx-text-fill: #d4af37; -fx-font-size: 16px; -fx-font-weight: bold;" />

            <HBox fx:id="summaryWifiRow" spacing="10" visible="false" managed="false">
                <Label text="• Wi-Fi:" style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
                <Label fx:id="summaryWifiLabel" text="" style="-fx-text-fill: white; -fx-font-size: 14px;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="summaryWifiPrice" text="" style="-fx-text-fill: #d4af37; -fx-font-size: 14px;" />
            </HBox>

            <HBox fx:id="summaryBreakfastRow" spacing="10" visible="false" managed="false">
                <Label text="• Breakfast:" style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
                <Label fx:id="summaryBreakfastLabel" text="" style="-fx-text-fill: white; -fx-font-size: 14px;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="summaryBreakfastPrice" text="" style="-fx-text-fill: #d4af37; -fx-font-size: 14px;" />
            </HBox>

            <HBox fx:id="summaryShuttleRow" spacing="10" visible="false" managed="false">
                <Label text="• Airport Shuttle:" style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
                <Label fx:id="summaryShuttleLabel" text="" style="-fx-text-fill: white; -fx-font-size: 14px;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="summaryShuttlePrice" text="" style="-fx-text-fill: #d4af37; -fx-font-size: 14px;" />
            </HBox>

            <HBox fx:id="summarySpaRow" spacing="10" visible="false" managed="false">
                <Label text="• Spa:" style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
                <Label fx:id="summarySpaLabel" text="" style="-fx-text-fill: white; -fx-font-size: 14px;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="summarySpaPrice" text="" style="-fx-text-fill: #d4af37; -fx-font-size: 14px;" />
            </HBox>

            <Separator />

            <!-- PRICE BREAKDOWN -->
            <Label text="PRICE BREAKDOWN" style="-fx-text-fill: #d4af37; -fx-font-size: 16px; -fx-font-weight: bold;" />
            <Label fx:id="subtotalLabel" text="Subtotal: $0" style="-fx-text-fill: white; -fx-font-size: 14px;" />
            <Label fx:id="taxLabel" text="Tax (13%): $0" style="-fx-text-fill: white; -fx-font-size: 14px;" />
            <Label fx:id="totalLabel" text="TOTAL: $0" style="-fx-text-fill: #d4af37; -fx-font-size: 28px; -fx-font-weight: bold;" />

            <Label fx:id="pricingTypeLabel" text="Pricing: Standard" style="-fx-text-fill: #a8a29e; -fx-font-size: 12px;" />

        </VBox>

        <!-- Buttons -->
        <HBox spacing="20">
            <Button onAction="#exportToCSV" text="📄 CSV" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100; -fx-pref-height: 40; -fx-cursor: hand; -fx-background-radius: 5;" />
            <Button onAction="#exportToPDF" text="📑 PDF" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100; -fx-pref-height: 40; -fx-cursor: hand; -fx-background-radius: 5;" />
            <Button onAction="#goToConfirmation" text="CONFIRM →" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 40; -fx-cursor: hand; -fx-background-radius: 5;" />
            <Button onAction="#goToLoyalty" text="← BACK" style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-pref-width: 120; -fx-pref-height: 40; -fx-cursor: hand; -fx-border-radius: 5;" />
        </HBox>

    </VBox>

</AnchorPane>