<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.SummaryController">

    <HBox alignment="CENTER" spacing="6.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="26.0">
        <Label text="1" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="2" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="3" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="4" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="5" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="6" style="-fx-text-fill: #c8a84b; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: rgba(200,168,75,0.12); -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #c8a84b; -fx-border-radius: 50; -fx-border-width: 1.5;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="7" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
    </HBox>

    <VBox alignment="CENTER" spacing="28.0"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
          style="-fx-padding: 0 68;">

        <VBox alignment="CENTER" spacing="6.0">
            <Label text="BOOKING SUMMARY"
                   style="-fx-text-fill: white; -fx-font-size: 40px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />
            <Label text="Step 6  -  Review and confirm your reservation"
                   style="-fx-text-fill: #54483a; -fx-font-size: 13px; -fx-letter-spacing: 2px;" />
        </VBox>

        <HBox alignment="TOP_CENTER" spacing="24.0" maxWidth="1180.0">

            <VBox spacing="14.0" prefWidth="490.0"
                  style="-fx-background-color: rgba(255,255,255,0.025);
                         -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                         -fx-background-radius: 14; -fx-border-radius: 14;
                         -fx-padding: 28 30;">

                <Label text="STAY DETAILS"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <VBox spacing="0.0"
                      style="-fx-background-color: #0f0f1a; -fx-background-radius: 10;
                             -fx-border-color: rgba(200,168,75,0.10); -fx-border-width: 1; -fx-border-radius: 10;">

                    <HBox spacing="10.0" style="-fx-padding: 13 18;
                                                -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Guest" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 100;" />
                        <Label fx:id="summaryGuestName" text="--"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>

                    <HBox spacing="10.0" style="-fx-padding: 13 18;
                                                -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Check-In" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 100;" />
                        <Label fx:id="summaryCheckIn" text="--"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>

                    <HBox spacing="10.0" style="-fx-padding: 13 18;
                                                -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Check-Out" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 100;" />
                        <Label fx:id="summaryCheckOut" text="--"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>

                    <HBox spacing="10.0" style="-fx-padding: 13 18;
                                                -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Duration" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 100;" />
                        <Label fx:id="summaryNights" text="--"
                               style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>

                    <HBox spacing="10.0" style="-fx-padding: 13 18;
                                                -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Guests" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 100;" />
                        <Label fx:id="summaryGuests" text="--"
                               style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>

                    <HBox spacing="10.0" style="-fx-padding: 13 18;">
                        <Label text="Room" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 100;" />
                        <Label fx:id="summaryRoomType" text="--"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>
                </VBox>

                <Label text="ADD-ON SERVICES"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <VBox spacing="0.0"
                      style="-fx-background-color: #0f0f1a; -fx-background-radius: 10;
                             -fx-border-color: rgba(200,168,75,0.10); -fx-border-width: 1; -fx-border-radius: 10;">

                    <HBox fx:id="summaryWifiRow" spacing="10.0" visible="false" managed="false"
                          style="-fx-padding: 13 18; -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="WiFi" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 120;" />
                        <Label fx:id="summaryWifiLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="summaryWifiPrice" text="--" style="-fx-text-fill: #c8a84b; -fx-font-size: 13px;" />
                    </HBox>

                    <HBox fx:id="summaryBreakfastRow" spacing="10.0" visible="false" managed="false"
                          style="-fx-padding: 13 18; -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Breakfast" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 120;" />
                        <Label fx:id="summaryBreakfastLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="summaryBreakfastPrice" text="--" style="-fx-text-fill: #c8a84b; -fx-font-size: 13px;" />
                    </HBox>

                    <HBox fx:id="summaryShuttleRow" spacing="10.0" visible="false" managed="false"
                          style="-fx-padding: 13 18; -fx-border-color: rgba(200,168,75,0.07); -fx-border-width: 0 0 1 0;">
                        <Label text="Shuttle" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 120;" />
                        <Label fx:id="summaryShuttleLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="summaryShuttlePrice" text="--" style="-fx-text-fill: #c8a84b; -fx-font-size: 13px;" />
                    </HBox>

                    <HBox fx:id="summarySpaRow" spacing="10.0" visible="false" managed="false"
                          style="-fx-padding: 13 18;">
                        <Label text="Spa" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px; -fx-pref-width: 120;" />
                        <Label fx:id="summarySpaLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="summarySpaPrice" text="--" style="-fx-text-fill: #c8a84b; -fx-font-size: 13px;" />
                    </HBox>

                </VBox>

            </VBox>

            <VBox spacing="18.0" prefWidth="340.0"
                  style="-fx-background-color: rgba(255,255,255,0.025);
                         -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                         -fx-background-radius: 14; -fx-border-radius: 14;
                         -fx-padding: 28 30;">

                <Label text="PRICE BREAKDOWN"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <VBox spacing="10.0"
                      style="-fx-background-color: #0f0f1a; -fx-background-radius: 10;
                             -fx-border-color: rgba(200,168,75,0.10); -fx-border-width: 1; -fx-border-radius: 10;
                             -fx-padding: 16 18;">
                    <HBox>
                        <Label text="Room Total" style="-fx-text-fill: #7a6a4a; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="summaryRoomPrice" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>
                    <HBox>
                        <Label text="Pricing Type" style="-fx-text-fill: #7a6a4a; -fx-font-size: 12px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="pricingTypeLabel" text="Standard" style="-fx-text-fill: #54483a; -fx-font-size: 12px;" />
                    </HBox>
                </VBox>

                <Separator style="-fx-background-color: rgba(200,168,75,0.15);" />

                <VBox spacing="10.0"
                      style="-fx-background-color: #0f0f1a; -fx-background-radius: 10;
                             -fx-border-color: rgba(200,168,75,0.10); -fx-border-width: 1; -fx-border-radius: 10;
                             -fx-padding: 16 18;">
                    <HBox>
                        <Label text="Subtotal" style="-fx-text-fill: #7a6a4a; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="subtotalLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>
                    <HBox>
                        <Label text="Tax (13% HST)" style="-fx-text-fill: #7a6a4a; -fx-font-size: 13px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="taxLabel" text="--" style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    </HBox>
                    <Separator style="-fx-background-color: rgba(200,168,75,0.15);" />
                    <HBox alignment="CENTER_LEFT">
                        <Label text="TOTAL DUE" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="totalLabel" text="--"
                               style="-fx-text-fill: #c8a84b; -fx-font-size: 22px; -fx-font-weight: bold;" />
                    </HBox>
                </VBox>

                <Region prefHeight="6.0" />

                <Label text="Tax (13%) applies. Payment collected at front desk on arrival."
                       style="-fx-text-fill: #3a3028; -fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>

                <Separator style="-fx-background-color: rgba(200,168,75,0.15);" />

                <HBox spacing="10.0">
                    <Button onAction="#exportToCSV" text="Export CSV"
                            style="-fx-background-color: #0f0f1a; -fx-text-fill: white;
                                   -fx-pref-height: 42; -fx-pref-width: 139;
                                   -fx-cursor: hand; -fx-background-radius: 8;
                                   -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1; -fx-border-radius: 8;
                                   -fx-font-size: 12px;" />
                    <Button onAction="#exportToPDF" text="Export PDF"
                            style="-fx-background-color: #0f0f1a; -fx-text-fill: white;
                                   -fx-pref-height: 42; -fx-pref-width: 139;
                                   -fx-cursor: hand; -fx-background-radius: 8;
                                   -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1; -fx-border-radius: 8;
                                   -fx-font-size: 12px;" />
                </HBox>

                <Button onAction="#goToConfirmation" text="CONFIRM BOOKING"
                        style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                               -fx-font-weight: bold; -fx-pref-height: 52; -fx-pref-width: 288;
                               -fx-cursor: hand; -fx-background-radius: 8;
                               -fx-font-size: 13px; -fx-letter-spacing: 1px;" />

                <Button onAction="#goToLoyalty" text="Back to Loyalty"
                        style="-fx-background-color: transparent; -fx-text-fill: #7a6a4a;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-underline: true;" />
            </VBox>

        </HBox>

    </VBox>

</AnchorPane>