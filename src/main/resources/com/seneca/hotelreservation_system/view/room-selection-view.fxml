<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.UIController">

    <VBox alignment="TOP_CENTER" spacing="50.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-padding: 60 0 0 0;">

        <VBox alignment="CENTER" spacing="15.0">
            <Label text="SELECT YOUR ELITE SUITE" style="-fx-text-fill: #d4af37; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-letter-spacing: 5px;" />
            <Label text="Step 1: Choose Your Experience" style="-fx-text-fill: #78716c; -fx-font-size: 16px; -fx-text-transform: uppercase; -fx-letter-spacing: 2px;" />
            <Hyperlink text="View Detailed Booking &amp; Cancellation Policy" style="-fx-text-fill: #d4af37; -fx-font-size: 14px; -fx-underline: true;" />
        </VBox>

        <HBox alignment="CENTER" maxWidth="1100.0" spacing="25.0" style="-fx-background-color: #0a0a0a; -fx-padding: 25; -fx-border-color: #d4af37; -fx-border-width: 1; -fx-background-radius: 5; -fx-border-radius: 5;">
            <effect><DropShadow color="#d4af371a" radius="15.0" /></effect>
            <DatePicker promptText="Check-in Date" style="-fx-pref-width: 220; -fx-font-size: 14px;" />
            <DatePicker promptText="Check-out Date" style="-fx-pref-width: 220; -fx-font-size: 14px;" />
            <TextField promptText="Adults" style="-fx-pref-width: 100; -fx-font-size: 14px;" />
            <TextField promptText="Children" style="-fx-pref-width: 100; -fx-font-size: 14px;" />
            <Button text="UPDATE SEARCH" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 45; -fx-cursor: hand;" />
        </HBox>

        <HBox alignment="CENTER" spacing="60.0">
            <VBox prefHeight="500.0" prefWidth="420.0" spacing="20.0" style="-fx-background-color: #0a0a0a; -fx-border-color: #44403c; -fx-border-width: 1; -fx-padding: 0 0 35 0; -fx-background-radius: 15; -fx-border-radius: 15;">
                <effect><DropShadow color="#000000aa" radius="20.0" offsetY="10.0" /></effect>
                <Region prefHeight="220.0" style="-fx-background-color: #1c1917; -fx-background-radius: 15 15 0 0; -fx-border-color: #d4af37; -fx-border-width: 0 0 1 0;" />
                <VBox spacing="10.0" style="-fx-padding: 0 35;">
                    <Label text="Standard Double" style="-fx-text-fill: #d4af37; -fx-font-size: 28px; -fx-font-weight: bold;" />
                    <Label text="2 Queen Beds • Courtyard View • 45 m²" style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
                    <Label text="Luxury Amenities • Complimentary Breakfast" style="-fx-text-fill: #78716c; -fx-font-size: 12px; -fx-font-style: italic;" />
                    <Region prefHeight="20.0" />
                    <Label text="150.00 USD / Night" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    <Button onAction="#goToGuestDetails" text="SELECT SUITE" style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-pref-width: 350; -fx-pref-height: 55; -fx-font-weight: bold; -fx-cursor: hand;" />
                </VBox>
            </VBox>

            <VBox prefHeight="500.0" prefWidth="420.0" spacing="20.0" style="-fx-background-color: #0a0a0a; -fx-border-color: #d4af37; -fx-border-width: 2; -fx-padding: 0 0 35 0; -fx-background-radius: 15; -fx-border-radius: 15;">
                <effect><DropShadow color="#d4af3733" radius="30.0" /></effect>
                <Region prefHeight="220.0" style="-fx-background-color: #1c1917; -fx-background-radius: 15 15 0 0; -fx-border-color: #d4af37; -fx-border-width: 0 0 2 0;" />
                <VBox spacing="10.0" style="-fx-padding: 0 35;">
                    <Label text="Royal King Suite" style="-fx-text-fill: #d4af37; -fx-font-size: 28px; -fx-font-weight: bold;" />
                    <Label text="1 King Bed • Panoramic Ocean View • 85 m²" style="-fx-text-fill: #a8a29e; -fx-font-size: 14px;" />
                    <Label text="VIP Concierge • Private Spa Access" style="-fx-text-fill: #78716c; -fx-font-size: 12px; -fx-font-style: italic;" />
                    <Region prefHeight="20.0" />
                    <Label text="320.00 USD / Night" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    <Button onAction="#goToGuestDetails" text="SELECT SUITE" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-pref-width: 350; -fx-pref-height: 55; -fx-font-weight: bold; -fx-cursor: hand;" />
                </VBox>
            </VBox>
        </HBox>

        <Button onAction="#goToWelcome" text="RETURN TO MAIN MENU" style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
    </VBox>

    <Button onAction="#showRules" text="RULES &amp; POLICIES" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0" style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-border-width: 0.5; -fx-cursor: hand; -fx-padding: 10 20;" />

</AnchorPane>