<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.RoomSelectionController">

    <AnchorPane.resources>
        <ToggleGroup fx:id="roomToggleGroup" />
    </AnchorPane.resources>

    <HBox alignment="CENTER" spacing="6.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="26.0">
        <Label text="1" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="2" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="3" style="-fx-text-fill: #c8a84b; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: rgba(200,168,75,0.12); -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #c8a84b; -fx-border-radius: 50; -fx-border-width: 1.5;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="4" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="5" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="6" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="7" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <content>
            <VBox alignment="TOP_CENTER" spacing="36.0" style="-fx-padding: 76 56 60 56;">

                <VBox alignment="CENTER" spacing="7.0">
                    <Label text="SELECT YOUR ROOM"
                           style="-fx-text-fill: white; -fx-font-size: 44px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />
                    <Label fx:id="searchSummaryLabel" text="Step 3  -  Choose your suite"
                           style="-fx-text-fill: #54483a; -fx-font-size: 13px; -fx-letter-spacing: 2px;" />
                </VBox>

                <VBox alignment="CENTER" spacing="7.0" maxWidth="700.0"
                      style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 10;
                             -fx-border-color: rgba(200,168,75,0.18); -fx-border-width: 1; -fx-border-radius: 10;
                             -fx-padding: 14 28;">
                    <Label fx:id="capacityLabel" text="Select a room type to check occupancy"
                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    <ProgressBar fx:id="capacityBar" prefWidth="500.0" prefHeight="4.0" progress="0.0"
                                 style="-fx-accent: #c8a84b; -fx-pref-height: 4;" />
                </VBox>

                <HBox alignment="CENTER" spacing="22.0">

                    <VBox fx:id="singleRoomCard" prefWidth="295.0" spacing="0.0"
                          style="-fx-background-color: #0d0d17;
                                 -fx-border-color: rgba(200,168,75,0.18); -fx-border-width: 1;
                                 -fx-background-radius: 14; -fx-border-radius: 14; -fx-cursor: hand;">
                        <effect><DropShadow color="#00000099" radius="18.0" offsetY="6.0" /></effect>
                        <VBox prefHeight="148.0" alignment="CENTER" spacing="8.0"
                              style="-fx-background-color: #161620; -fx-background-radius: 14 14 0 0;
                                     -fx-border-color: rgba(200,168,75,0.15); -fx-border-width: 0 0 1 0;">
                            <Label text="Single" style="-fx-text-fill: #5a4a2a; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />
                            <Label text="Single Bed" style="-fx-text-fill: #3a3028; -fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="9.0" style="-fx-padding: 22 24 26 24;">
                            <HBox alignment="CENTER_LEFT" spacing="9.0">
                                <RadioButton fx:id="singleRoomRadio" onAction="#onRoomSelected"
                                             toggleGroup="$roomToggleGroup" />
                                <Label text="Single Room"
                                       style="-fx-text-fill: #c8a84b; -fx-font-size: 19px; -fx-font-weight: bold;" />
                            </HBox>
                            <Label text="1 Queen Bed  -  25 m2  -  Max 2 guests"
                                   style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                            <Label text="Free WiFi, Smart TV, Mini Fridge"
                                   style="-fx-text-fill: #4a4030; -fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>
                            <Region prefHeight="4.0" />
                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                <Label text="$89" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />
                                <Label text="/ night" style="-fx-text-fill: #54483a; -fx-font-size: 12px;" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="Qty" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                <ComboBox fx:id="singleRoomQty" prefWidth="76" prefHeight="34"
                                          style="-fx-font-size: 13px;" />
                            </HBox>
                            <Button onAction="#selectSingle" text="SELECT"
                                    style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                                           -fx-border-color: #c8a84b; -fx-border-width: 1;
                                           -fx-pref-width: 247; -fx-pref-height: 40;
                                           -fx-font-weight: bold; -fx-cursor: hand;
                                           -fx-background-radius: 8; -fx-border-radius: 8;
                                           -fx-letter-spacing: 1px;" />
                        </VBox>
                    </VBox>

                    <VBox fx:id="doubleRoomCard" prefWidth="295.0" spacing="0.0"
                          style="-fx-background-color: #0d0d17;
                                 -fx-border-color: rgba(200,168,75,0.18); -fx-border-width: 1;
                                 -fx-background-radius: 14; -fx-border-radius: 14; -fx-cursor: hand;">
                        <effect><DropShadow color="#00000099" radius="18.0" offsetY="6.0" /></effect>
                        <VBox prefHeight="148.0" alignment="CENTER" spacing="8.0"
                              style="-fx-background-color: #161620; -fx-background-radius: 14 14 0 0;
                                     -fx-border-color: rgba(200,168,75,0.15); -fx-border-width: 0 0 1 0;">
                            <Label text="Double" style="-fx-text-fill: #5a4a2a; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />
                            <Label text="Twin Beds" style="-fx-text-fill: #3a3028; -fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="9.0" style="-fx-padding: 22 24 26 24;">
                            <HBox alignment="CENTER_LEFT" spacing="9.0">
                                <RadioButton fx:id="doubleRoomRadio" onAction="#onRoomSelected"
                                             toggleGroup="$roomToggleGroup" />
                                <Label text="Double Room"
                                       style="-fx-text-fill: #c8a84b; -fx-font-size: 19px; -fx-font-weight: bold;" />
                            </HBox>
                            <Label text="2 Queen Beds  -  45 m2  -  Max 4 guests"
                                   style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                            <Label text="Courtyard View, Complimentary Breakfast"
                                   style="-fx-text-fill: #4a4030; -fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>
                            <Region prefHeight="4.0" />
                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                <Label text="$129" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />
                                <Label text="/ night" style="-fx-text-fill: #54483a; -fx-font-size: 12px;" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="Qty" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                <ComboBox fx:id="doubleRoomQty" prefWidth="76" prefHeight="34"
                                          style="-fx-font-size: 13px;" />
                            </HBox>
                            <Button onAction="#selectStandardDouble" text="SELECT"
                                    style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                                           -fx-border-color: #c8a84b; -fx-border-width: 1;
                                           -fx-pref-width: 247; -fx-pref-height: 40;
                                           -fx-font-weight: bold; -fx-cursor: hand;
                                           -fx-background-radius: 8; -fx-border-radius: 8;
                                           -fx-letter-spacing: 1px;" />
                        </VBox>
                    </VBox>

                    <VBox fx:id="deluxeRoomCard" prefWidth="295.0" spacing="0.0"
                          style="-fx-background-color: #0d0d17;
                                 -fx-border-color: rgba(200,168,75,0.18); -fx-border-width: 1;
                                 -fx-background-radius: 14; -fx-border-radius: 14; -fx-cursor: hand;">
                        <effect><DropShadow color="#00000099" radius="18.0" offsetY="6.0" /></effect>
                        <VBox prefHeight="148.0" alignment="CENTER" spacing="8.0"
                              style="-fx-background-color: #161620; -fx-background-radius: 14 14 0 0;
                                     -fx-border-color: rgba(200,168,75,0.15); -fx-border-width: 0 0 1 0;">
                            <Label text="Deluxe" style="-fx-text-fill: #5a4a2a; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />
                            <Label text="King Bed" style="-fx-text-fill: #3a3028; -fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="9.0" style="-fx-padding: 22 24 26 24;">
                            <HBox alignment="CENTER_LEFT" spacing="9.0">
                                <RadioButton fx:id="deluxeRoomRadio" onAction="#onRoomSelected"
                                             toggleGroup="$roomToggleGroup" />
                                <Label text="Deluxe Room"
                                       style="-fx-text-fill: #c8a84b; -fx-font-size: 19px; -fx-font-weight: bold;" />
                            </HBox>
                            <Label text="King Bed  -  45 m2  -  Max 2 guests"
                                   style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                            <Label text="City View, Luxury Bathroom, Mini Bar"
                                   style="-fx-text-fill: #4a4030; -fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>
                            <Region prefHeight="4.0" />
                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                <Label text="$199" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />
                                <Label text="/ night" style="-fx-text-fill: #54483a; -fx-font-size: 12px;" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="Qty" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                <ComboBox fx:id="deluxeRoomQty" prefWidth="76" prefHeight="34"
                                          style="-fx-font-size: 13px;" />
                            </HBox>
                            <Button onAction="#selectDeluxe" text="SELECT"
                                    style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                                           -fx-border-color: #c8a84b; -fx-border-width: 1;
                                           -fx-pref-width: 247; -fx-pref-height: 40;
                                           -fx-font-weight: bold; -fx-cursor: hand;
                                           -fx-background-radius: 8; -fx-border-radius: 8;
                                           -fx-letter-spacing: 1px;" />
                        </VBox>
                    </VBox>

                    <VBox fx:id="penthouseCard" prefWidth="295.0" spacing="0.0"
                          style="-fx-background-color: #100f00;
                                 -fx-border-color: #c8a84b; -fx-border-width: 1.5;
                                 -fx-background-radius: 14; -fx-border-radius: 14; -fx-cursor: hand;">
                        <effect><DropShadow color="#c8a84b33" radius="28.0" /></effect>
                        <VBox prefHeight="148.0" alignment="CENTER" spacing="8.0"
                              style="-fx-background-color: #18150a; -fx-background-radius: 14 14 0 0;
                                     -fx-border-color: #c8a84b; -fx-border-width: 0 0 1 0;">
                            <Label text="PREMIUM" style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />
                            <Label text="Penthouse" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="9.0" style="-fx-padding: 22 24 26 24;">
                            <HBox alignment="CENTER_LEFT" spacing="9.0">
                                <RadioButton fx:id="penthouseRadio" onAction="#onRoomSelected"
                                             toggleGroup="$roomToggleGroup" />
                                <Label text="Penthouse Suite"
                                       style="-fx-text-fill: #c8a84b; -fx-font-size: 17px; -fx-font-weight: bold;" />
                            </HBox>
                            <Label text="King Bed  -  85 m2  -  Max 2 guests"
                                   style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                            <Label text="Panoramic View, Jacuzzi, Private Spa"
                                   style="-fx-text-fill: #4a4030; -fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>
                            <Region prefHeight="4.0" />
                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                <Label text="$349" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />
                                <Label text="/ night" style="-fx-text-fill: #54483a; -fx-font-size: 12px;" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="Qty" style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                <ComboBox fx:id="penthouseQty" prefWidth="76" prefHeight="34"
                                          style="-fx-font-size: 13px;" />
                            </HBox>
                            <Button onAction="#selectRoyalKing" text="SELECT"
                                    style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                                           -fx-pref-width: 247; -fx-pref-height: 40;
                                           -fx-font-weight: bold; -fx-cursor: hand;
                                           -fx-background-radius: 8; -fx-letter-spacing: 1px;" />
                        </VBox>
                    </VBox>

                </HBox>

                <Label text="Occupancy Policy: Single / Deluxe / Penthouse accept max 2 guests. Double accepts max 4 guests."
                       style="-fx-text-fill: #3a3028; -fx-font-size: 11px; -fx-font-style: italic;" />

                <HBox alignment="CENTER" spacing="20.0">
                    <Button onAction="#goToSearch" text="Back"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a6a4a;
                                   -fx-font-size: 13px; -fx-cursor: hand; -fx-underline: true;" />
                    <Button onAction="#goToWelcome" text="Return to Home"
                            style="-fx-background-color: transparent; -fx-text-fill: #54483a;
                                   -fx-font-size: 12px; -fx-cursor: hand;" />
                </HBox>

            </VBox>
        </content>
    </ScrollPane>

    <Button onAction="#showRules" text="RULES AND POLICIES"
            AnchorPane.rightAnchor="38.0" AnchorPane.topAnchor="38.0"
            style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                   -fx-border-color: #c8a84b; -fx-border-width: 1;
                   -fx-cursor: hand; -fx-padding: 9 16;
                   -fx-background-radius: 6; -fx-border-radius: 6;
                   -fx-font-size: 11px; -fx-letter-spacing: 1px;" />

</AnchorPane>