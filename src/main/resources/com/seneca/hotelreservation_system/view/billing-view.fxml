<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #020617;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.BillingController">

    <VBox prefWidth="280.0"
          spacing="15.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          style="-fx-background-color: #0a0a0a; -fx-padding: 40 25; -fx-border-color: #d4af37; -fx-border-width: 0 1 0 0;">

        <Label text="GRAND PLAZA"
               style="-fx-text-fill: #d4af37; -fx-font-size: 22px; -fx-font-weight: bold;" />

        <Region prefHeight="30.0" />

        <Button text="BACK TO DASHBOARD"
                onAction="#goBack"
                style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 230; -fx-pref-height: 45;" />
    </VBox>

    <VBox spacing="18.0"
          AnchorPane.bottomAnchor="20.0"
          AnchorPane.leftAnchor="300.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.topAnchor="20.0">

        <Label text="Billing Management"
               style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />

        <HBox spacing="18.0" VBox.vgrow="ALWAYS">
            <VBox spacing="12.0" prefWidth="700.0" HBox.hgrow="ALWAYS">
                <HBox spacing="10.0"
                      style="-fx-background-color: #0a0a0a; -fx-padding: 12; -fx-border-color: #44403c;">
                    <TextField fx:id="reservationSearchField"
                               promptText="Search reservation guest or phone"
                               style="-fx-pref-width: 260;" />
                    <ComboBox fx:id="billingStatusFilterCombo"
                              style="-fx-pref-width: 150;" />
                    <Button text="REFRESH"
                            onAction="#handleRefresh"
                            style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 130;" />
                </HBox>

                <TableView fx:id="reservationTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="reservationRefColumn" text="REF ID" prefWidth="90.0" />
                        <TableColumn fx:id="reservationGuestColumn" text="GUEST" prefWidth="220.0" />
                        <TableColumn fx:id="reservationStatusColumn" text="STATUS" prefWidth="120.0" />
                        <TableColumn fx:id="reservationTotalColumn" text="TOTAL" prefWidth="120.0" />
                        <TableColumn fx:id="reservationBalanceColumn" text="BALANCE" prefWidth="120.0" />
                    </columns>
                </TableView>

                <Label text="Payment History"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <TableView fx:id="paymentTable" prefHeight="260.0">
                    <columns>
                        <TableColumn fx:id="paymentIdColumn" text="PAYMENT ID" prefWidth="110.0" />
                        <TableColumn fx:id="paymentDateColumn" text="DATE" prefWidth="200.0" />
                        <TableColumn fx:id="paymentMethodColumn" text="METHOD" prefWidth="120.0" />
                        <TableColumn fx:id="paymentAmountColumn" text="AMOUNT" prefWidth="120.0" />
                        <TableColumn fx:id="paymentRefundColumn" text="REFUND" prefWidth="100.0" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="12.0"
                  prefWidth="380.0"
                  style="-fx-background-color: #0a0a0a; -fx-padding: 18; -fx-border-color: #44403c;">

                <Label text="Billing Actions"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <Label fx:id="selectedReservationLabel"
                       text="Selected Reservation: None"
                       wrapText="true"
                       style="-fx-text-fill: #d4af37;" />

                <Label fx:id="totalPaidLabel"
                       text="Total Paid: $0.00"
                       style="-fx-text-fill: white;" />

                <Label fx:id="balanceLabel"
                       text="Outstanding Balance: $0.00"
                       style="-fx-text-fill: #facc15;" />

                <TextField fx:id="amountField"
                           promptText="Amount"
                           style="-fx-pref-height: 38;" />

                <ComboBox fx:id="paymentMethodCombo"
                          style="-fx-pref-height: 38;" />

                <TextArea fx:id="notesArea"
                          promptText="Optional notes"
                          wrapText="true"
                          prefHeight="160.0" />

                <Button text="PROCESS PAYMENT"
                        onAction="#handleProcessPayment"
                        style="-fx-background-color: #22c55e; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-height: 42;" />

                <Button text="PROCESS REFUND"
                        onAction="#handleProcessRefund"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 42;" />

                <Label fx:id="billingStatusLabel"
                       text=""
                       wrapText="true"
                       style="-fx-text-fill: #d4af37;" />
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>