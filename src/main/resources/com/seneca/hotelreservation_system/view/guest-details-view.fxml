<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.UIController">

    <VBox alignment="CENTER" spacing="30.0"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="6.0">
            <Label text="GUEST REGISTRATION"
                   style="-fx-text-fill: white; -fx-font-size: 40px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />
            <Label text="Enter your details or look up your loyalty account"
                   style="-fx-text-fill: #54483a; -fx-font-size: 13px; -fx-letter-spacing: 2px;" />
        </VBox>

        <HBox alignment="CENTER" spacing="28.0">

            <VBox spacing="18.0" prefWidth="440.0"
                  style="-fx-background-color: rgba(255,255,255,0.025);
                         -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                         -fx-background-radius: 14; -fx-border-radius: 14;
                         -fx-padding: 32 30;">

                <Label text="CONTACT INFORMATION"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <VBox spacing="6.0">
                    <Label text="PHONE NUMBER - Loyalty Lookup"
                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 10px; -fx-letter-spacing: 2px; -fx-font-weight: bold;" />
                    <TextField fx:id="phoneField" promptText="10-digit number"
                               style="-fx-pref-height: 44; -fx-font-size: 13px;
                                      -fx-background-color: #0f0f1a; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #3a3630;
                                      -fx-border-color: rgba(200,168,75,0.22); -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;" />
                </VBox>

                <VBox spacing="6.0">
                    <Label text="FULL NAME"
                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 10px; -fx-letter-spacing: 2px; -fx-font-weight: bold;" />
                    <TextField fx:id="nameField" promptText="e.g. John Smith"
                               style="-fx-pref-height: 44; -fx-font-size: 13px;
                                      -fx-background-color: #0f0f1a; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #3a3630;
                                      -fx-border-color: rgba(200,168,75,0.22); -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;" />
                </VBox>

                <VBox spacing="6.0">
                    <Label text="EMAIL ADDRESS"
                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 10px; -fx-letter-spacing: 2px; -fx-font-weight: bold;" />
                    <TextField fx:id="emailField" promptText="john@example.com"
                               style="-fx-pref-height: 44; -fx-font-size: 13px;
                                      -fx-background-color: #0f0f1a; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #3a3630;
                                      -fx-border-color: rgba(200,168,75,0.22); -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;" />
                </VBox>

                <Region prefHeight="4.0" />

                <Button onAction="#goToAddons" text="CONTINUE TO SERVICES"
                        style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                               -fx-font-weight: bold; -fx-pref-height: 50; -fx-pref-width: 380;
                               -fx-cursor: hand; -fx-background-radius: 8;
                               -fx-font-size: 13px; -fx-letter-spacing: 1px;" />
            </VBox>

            <VBox spacing="14.0" alignment="TOP_CENTER" prefWidth="260.0"
                  style="-fx-background-color: rgba(200,168,75,0.04);
                         -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                         -fx-background-radius: 14; -fx-border-radius: 14;
                         -fx-padding: 28 24;">

                <Label text="LOYALTY STATUS"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <Label fx:id="lblLoyaltyPoints" text="0 Points"
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />

                <Label text="Enter your phone number above to check existing loyalty status and auto-fill your details."
                       style="-fx-text-fill: #54483a; -fx-font-size: 12px;" wrapText="true"/>
            </VBox>
        </HBox>

    </VBox>

    <Button onAction="#showRules" text="RULES AND POLICIES"
            AnchorPane.rightAnchor="38.0" AnchorPane.topAnchor="38.0"
            style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                   -fx-border-color: rgba(200,168,75,0.5); -fx-border-width: 1;
                   -fx-cursor: hand; -fx-padding: 9 16;
                   -fx-background-radius: 6; -fx-border-radius: 6;
                   -fx-font-size: 11px; -fx-letter-spacing: 1px;" />

</AnchorPane>