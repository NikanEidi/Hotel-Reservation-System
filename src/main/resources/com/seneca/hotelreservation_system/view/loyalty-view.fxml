<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.LoyaltyController">

    <fx:define>
        <ToggleGroup fx:id="enrollGroup" />
    </fx:define>

    <HBox alignment="CENTER" spacing="6.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="26.0">
        <Label text="1" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="2" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="3" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="4" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="5" style="-fx-text-fill: #c8a84b; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: rgba(200,168,75,0.12); -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #c8a84b; -fx-border-radius: 50; -fx-border-width: 1.5;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="6" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="7" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
    </HBox>

    <VBox alignment="CENTER" spacing="28.0"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
          style="-fx-padding: 0 120;">

        <VBox alignment="CENTER" spacing="7.0">
            <Label text="LOYALTY PROGRAM"
                   style="-fx-text-fill: #c8a84b; -fx-font-size: 11px; -fx-letter-spacing: 4px; -fx-font-weight: bold;" />
            <Label text="Earn Rewards on Every Stay"
                   style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />
            <Label text="Step 5  -  Loyalty enrollment"
                   style="-fx-text-fill: #54483a; -fx-font-size: 13px; -fx-letter-spacing: 2px;" />
        </VBox>

        <HBox alignment="CENTER" spacing="24.0" maxWidth="860.0">

            <VBox spacing="14.0" prefWidth="360.0"
                  style="-fx-background-color: rgba(255,255,255,0.025);
                         -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                         -fx-background-radius: 14; -fx-border-radius: 14;
                         -fx-padding: 30 28;">

                <Label text="PROGRAM BENEFITS"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <Region prefHeight="4.0" />

                <VBox spacing="14.0">
                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <Label text="*" style="-fx-text-fill: #c8a84b; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        <VBox spacing="2.0">
                            <Label text="Earn 1 point per $10 spent"
                                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            <Label text="Points accumulate automatically on each stay"
                                   style="-fx-text-fill: #54483a; -fx-font-size: 11px;" />
                        </VBox>
                    </HBox>

                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <Label text="*" style="-fx-text-fill: #c8a84b; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        <VBox spacing="2.0">
                            <Label text="Redeem: 100 points = $10 discount"
                                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            <Label text="Apply at checkout anytime"
                                   style="-fx-text-fill: #54483a; -fx-font-size: 11px;" />
                        </VBox>
                    </HBox>

                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <Label text="*" style="-fx-text-fill: #c8a84b; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        <VBox spacing="2.0">
                            <Label text="Complimentary room upgrades"
                                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            <Label text="Subject to availability at check-in"
                                   style="-fx-text-fill: #54483a; -fx-font-size: 11px;" />
                        </VBox>
                    </HBox>

                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <Label text="*" style="-fx-text-fill: #c8a84b; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        <VBox spacing="2.0">
                            <Label text="Exclusive member-only rates"
                                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            <Label text="Up to 20% off on select promotions"
                                   style="-fx-text-fill: #54483a; -fx-font-size: 11px;" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <VBox spacing="18.0" prefWidth="360.0"
                  style="-fx-background-color: rgba(255,255,255,0.025);
                         -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                         -fx-background-radius: 14; -fx-border-radius: 14;
                         -fx-padding: 30 28;">

                <Label text="JOIN TODAY"
                       style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                <Label text="Would you like to enroll in the Grand Plaza Loyalty Program?"
                       style="-fx-text-fill: white; -fx-font-size: 14px;" wrapText="true"/>

                <Label text="Your contact information will be used from the details you entered. A loyalty number will be issued at the front desk upon first check-in."
                       style="-fx-text-fill: #54483a; -fx-font-size: 12px;" wrapText="true"/>

                <Region prefHeight="6.0" />

                <VBox spacing="10.0">
                    <RadioButton fx:id="enrollYesBtn"
                                 text="Yes, enroll me in the loyalty program"
                                 toggleGroup="$enrollGroup"
                                 style="-fx-text-fill: white; -fx-font-size: 13px;" />
                    <RadioButton fx:id="enrollNoBtn"
                                 text="No thanks, skip for now"
                                 toggleGroup="$enrollGroup"
                                 style="-fx-text-fill: #54483a; -fx-font-size: 13px;" />
                </VBox>

                <Region prefHeight="12.0" />

                <Separator style="-fx-background-color: rgba(200,168,75,0.15);" />

                <Region prefHeight="4.0" />

                <Button onAction="#goToSummary" text="CONTINUE"
                        style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                               -fx-font-weight: bold; -fx-pref-height: 50; -fx-pref-width: 248;
                               -fx-cursor: hand; -fx-background-radius: 8;
                               -fx-font-size: 13px; -fx-letter-spacing: 1px;" />

                <Button onAction="#goToAddOns" text="Back to Services"
                        style="-fx-background-color: transparent; -fx-text-fill: #7a6a4a;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-underline: true;" />
            </VBox>

        </HBox>

    </VBox>

</AnchorPane>