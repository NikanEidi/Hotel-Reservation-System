<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #020617;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.UIController">

    <StackPane AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0"
               AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER"
              maxWidth="600.0"
              prefHeight="550.0"
              spacing="40.0"
              style="-fx-background-color: #0a0a0a; -fx-border-color: #d4af37; -fx-border-width: 2; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 60;">

            <effect>
                <DropShadow color="#d4af3733" radius="30.0" />
            </effect>

            <Label text="GRAND PLAZA"
                   style="-fx-text-fill: #d4af37; -fx-font-size: 52px; -fx-font-weight: bold; -fx-font-family: 'Serif';" />

            <Separator maxWidth="300.0"
                       style="-fx-background-color: #d4af37; -fx-opacity: 0.3;" />

            <Button text="START RESERVATION"
                    onAction="#goToSearch"
                    style="-fx-background-color: #d4af37; -fx-text-fill: #000000; -fx-font-size: 18px; -fx-font-weight: bold; -fx-pref-width: 380; -fx-pref-height: 60; -fx-cursor: hand;" />

            <Button text="Administrator Login"
                    onAction="#goToAdminLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-font-size: 14px; -fx-border-color: #d4af37; -fx-pref-width: 200; -fx-pref-height: 40; -fx-cursor: hand;" />
        </VBox>
    </StackPane>

    <Button text="RULES &amp; POLICIES"
            onAction="#showRules"
            AnchorPane.rightAnchor="40.0"
            AnchorPane.topAnchor="40.0"
            style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-cursor: hand;" />
</AnchorPane>