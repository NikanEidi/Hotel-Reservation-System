<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.UIController">

    <VBox AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          alignment="CENTER" spacing="0.0">

        <Region prefHeight="56.0" />

        <Label text="GRAND PLAZA HOTEL"
               style="-fx-text-fill: #c8a84b; -fx-font-size: 12px; -fx-font-weight: bold; -fx-letter-spacing: 6px;" />

        <Region prefHeight="18.0" />

        <Label text="Grand Plaza"
               style="-fx-text-fill: white; -fx-font-size: 74px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />

        <Label text="TORONTO  -  EST. 1985"
               style="-fx-text-fill: #5a4a2a; -fx-font-size: 13px; -fx-letter-spacing: 4px;" />

        <Region prefHeight="42.0" />

        <Separator maxWidth="100.0"
                   style="-fx-background-color: #c8a84b; -fx-pref-height: 1;" />

        <Region prefHeight="42.0" />

        <VBox alignment="CENTER" spacing="14.0" maxWidth="460.0"
              style="-fx-background-color: rgba(255,255,255,0.025);
                     -fx-background-radius: 16;
                     -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1; -fx-border-radius: 16;
                     -fx-padding: 46 52 46 52;">
            <effect><DropShadow color="#c8a84b1a" radius="38.0" /></effect>

            <Label text="SELF-SERVICE KIOSK"
                   style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

            <Region prefHeight="6.0" />

            <Button text="BEGIN RESERVATION"
                    onAction="#goToSearch"
                    style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-pref-width: 356; -fx-pref-height: 56;
                           -fx-cursor: hand; -fx-background-radius: 8;
                           -fx-letter-spacing: 2px;" />

            <Button text="ADMINISTRATOR LOGIN"
                    onAction="#goToAdminLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-border-color: rgba(200,168,75,0.5); -fx-border-width: 1;
                           -fx-pref-width: 356; -fx-pref-height: 44;
                           -fx-cursor: hand; -fx-background-radius: 8; -fx-border-radius: 8;" />
        </VBox>

        <Region prefHeight="48.0" />

        <HBox alignment="CENTER" spacing="32.0">
            <Label text="Pool" style="-fx-text-fill: #44403c; -fx-font-size: 12px; -fx-letter-spacing: 1px;" />
            <Label text="-" style="-fx-text-fill: #c8a84b; -fx-font-size: 10px;" />
            <Label text="Fine Dining" style="-fx-text-fill: #44403c; -fx-font-size: 12px; -fx-letter-spacing: 1px;" />
            <Label text="-" style="-fx-text-fill: #c8a84b; -fx-font-size: 10px;" />
            <Label text="Spa" style="-fx-text-fill: #44403c; -fx-font-size: 12px; -fx-letter-spacing: 1px;" />
            <Label text="-" style="-fx-text-fill: #c8a84b; -fx-font-size: 10px;" />
            <Label text="Valet Parking" style="-fx-text-fill: #44403c; -fx-font-size: 12px; -fx-letter-spacing: 1px;" />
        </HBox>

        <Region VBox.vgrow="ALWAYS" />
    </VBox>

    <Button text="RULES AND POLICIES"
            onAction="#showRules"
            AnchorPane.rightAnchor="38.0"
            AnchorPane.topAnchor="38.0"
            style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                   -fx-border-color: rgba(200,168,75,0.5); -fx-border-width: 1;
                   -fx-cursor: hand; -fx-padding: 9 16;
                   -fx-background-radius: 6; -fx-border-radius: 6;
                   -fx-font-size: 11px; -fx-letter-spacing: 1px;" />

</AnchorPane>