<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #020617;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.FeedbackController">

    <VBox prefWidth="280.0"
          spacing="15.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          style="-fx-background-color: #0a0a0a; -fx-padding: 40 25; -fx-border-color: #d4af37; -fx-border-width: 0 1 0 0;">

        <Label text="GRAND PLAZA"
               style="-fx-text-fill: #d4af37; -fx-font-size: 22px; -fx-font-weight: bold;" />

        <Region prefHeight="30.0" />

        <Button text="BACK TO DASHBOARD"
                onAction="#goBack"
                style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 230; -fx-pref-height: 45;" />
    </VBox>

    <VBox spacing="18.0"
          AnchorPane.bottomAnchor="20.0"
          AnchorPane.leftAnchor="300.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.topAnchor="20.0">

        <Label text="Feedback Management"
               style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />

        <HBox spacing="18.0" VBox.vgrow="ALWAYS">
            <VBox spacing="12.0" prefWidth="620.0" HBox.hgrow="ALWAYS">
                <Label text="Eligible Checked-Out Reservations"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <HBox spacing="10.0"
                      style="-fx-background-color: #0a0a0a; -fx-padding: 12; -fx-border-color: #44403c;">
                    <TextField fx:id="eligibleSearchField"
                               promptText="Search guest or phone"
                               style="-fx-pref-width: 260;" />
                    <Button text="REFRESH"
                            onAction="#handleRefresh"
                            style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 120;" />
                </HBox>

                <TableView fx:id="eligibleTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="eligibleRefColumn" text="REF ID" prefWidth="90.0" />
                        <TableColumn fx:id="eligibleGuestColumn" text="GUEST" prefWidth="210.0" />
                        <TableColumn fx:id="eligibleDateColumn" text="DATES" prefWidth="220.0" />
                        <TableColumn fx:id="eligibleStatusColumn" text="STATUS" prefWidth="120.0" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="12.0"
                  prefWidth="420.0"
                  style="-fx-background-color: #0a0a0a; -fx-padding: 18; -fx-border-color: #44403c;">

                <Label text="Submit Feedback"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <Label fx:id="selectedReservationLabel"
                       text="Selected Reservation: None"
                       wrapText="true"
                       style="-fx-text-fill: #d4af37;" />

                <HBox spacing="10.0">
                    <Label text="Rating"
                           style="-fx-text-fill: #d6d3d1;" />
                    <ComboBox fx:id="ratingCombo" style="-fx-pref-width: 120;" />
                </HBox>

                <TextArea fx:id="commentArea"
                          promptText="Enter feedback comment"
                          wrapText="true"
                          prefHeight="180.0" />

                <Button text="SUBMIT FEEDBACK"
                        onAction="#handleSubmitFeedback"
                        style="-fx-background-color: #22c55e; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-height: 42;" />

                <Label fx:id="submitStatusLabel"
                       text=""
                       wrapText="true"
                       style="-fx-text-fill: #facc15;" />
            </VBox>
        </HBox>

        <Label text="Submitted Feedback"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

        <HBox spacing="10.0"
              style="-fx-background-color: #0a0a0a; -fx-padding: 12; -fx-border-color: #44403c;">
            <TextField fx:id="feedbackSearchField"
                       promptText="Search reservation or guest"
                       style="-fx-pref-width: 260;" />
            <ComboBox fx:id="sentimentFilterCombo" style="-fx-pref-width: 140;" />
            <ComboBox fx:id="minRatingCombo" style="-fx-pref-width: 120;" />
            <Button text="FILTER / REFRESH"
                    onAction="#handleRefresh"
                    style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 160;" />
        </HBox>

        <TableView fx:id="feedbackTable" prefHeight="230.0">
            <columns>
                <TableColumn fx:id="feedbackRefColumn" text="REF ID" prefWidth="100.0" />
                <TableColumn fx:id="feedbackGuestColumn" text="GUEST" prefWidth="220.0" />
                <TableColumn fx:id="feedbackRatingColumn" text="RATING" prefWidth="100.0" />
                <TableColumn fx:id="feedbackSentimentColumn" text="SENTIMENT" prefWidth="150.0" />
                <TableColumn fx:id="feedbackDateColumn" text="DATE" prefWidth="220.0" />
            </columns>
        </TableView>
    </VBox>
</AnchorPane>