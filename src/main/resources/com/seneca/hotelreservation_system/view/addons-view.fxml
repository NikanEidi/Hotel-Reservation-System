<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #08080f;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.seneca.hotelreservation_system.controller.AddOnsController">

    <HBox alignment="CENTER" spacing="6.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="26.0">
        <Label text="1" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="2" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="3" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="4" style="-fx-text-fill: #c8a84b; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: rgba(200,168,75,0.12); -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #c8a84b; -fx-border-radius: 50; -fx-border-width: 1.5;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="5" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="6" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
        <Label text="--------" style="-fx-text-fill: #2a2018; -fx-font-size: 9px;"/>
        <Label text="7" style="-fx-text-fill: #54483a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #1a1a1f; -fx-background-radius: 50; -fx-padding: 4 9; -fx-border-color: #3a3028; -fx-border-radius: 50; -fx-border-width: 1;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <content>
            <VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-padding: 76 76 56 76;">

                <VBox alignment="CENTER" spacing="7.0">
                    <Label text="ENHANCE YOUR STAY"
                           style="-fx-text-fill: white; -fx-font-size: 44px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" />
                    <Label text="Step 4  -  Select premium add-on services"
                           style="-fx-text-fill: #54483a; -fx-font-size: 13px; -fx-letter-spacing: 2px;" />
                </VBox>

                <HBox alignment="TOP_CENTER" spacing="24.0">

                    <VBox spacing="14.0" prefWidth="560.0"
                          style="-fx-background-color: rgba(255,255,255,0.025);
                                 -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                                 -fx-background-radius: 14; -fx-border-radius: 14;
                                 -fx-padding: 30 32;">
                        <effect><DropShadow color="#00000088" radius="18.0" /></effect>

                        <Label text="SERVICES"
                               style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                        <Region prefHeight="4.0" />

                        <VBox spacing="0.0"
                              style="-fx-background-color: #0f0f1a; -fx-background-radius: 10;
                                     -fx-border-color: rgba(200,168,75,0.12); -fx-border-width: 1; -fx-border-radius: 10;">

                            <HBox alignment="CENTER_LEFT" spacing="12.0"
                                  style="-fx-padding: 16 18;
                                         -fx-border-color: rgba(200,168,75,0.08); -fx-border-width: 0 0 1 0;">
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label text="High-Speed WiFi"
                                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                    <Label text="9.99 per device per night"
                                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                </VBox>
                                <CheckBox fx:id="wifiCheck" style="-fx-scale-x: 1.2; -fx-scale-y: 1.2;" />
                                <Spinner fx:id="wifiSpinner" prefWidth="70" prefHeight="34" editable="true" />
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="12.0"
                                  style="-fx-padding: 16 18;
                                         -fx-border-color: rgba(200,168,75,0.08); -fx-border-width: 0 0 1 0;">
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label text="Daily Breakfast Package"
                                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                    <Label text="24.99 per person per night"
                                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                </VBox>
                                <CheckBox fx:id="breakfastCheck" style="-fx-scale-x: 1.2; -fx-scale-y: 1.2;" />
                                <Spinner fx:id="breakfastSpinner" prefWidth="70" prefHeight="34" editable="true" />
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="12.0"
                                  style="-fx-padding: 16 18;
                                         -fx-border-color: rgba(200,168,75,0.08); -fx-border-width: 0 0 1 0;">
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label text="Airport Shuttle"
                                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                    <Label text="35.00 per trip"
                                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                </VBox>
                                <CheckBox fx:id="shuttleCheck" style="-fx-scale-x: 1.2; -fx-scale-y: 1.2;" />
                                <Spinner fx:id="shuttleSpinner" prefWidth="70" prefHeight="34" editable="true" />
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 16 18;">
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label text="Spa and Wellness"
                                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                    <Label text="49.99 per session"
                                           style="-fx-text-fill: #7a6a4a; -fx-font-size: 11px;" />
                                </VBox>
                                <CheckBox fx:id="spaCheck" style="-fx-scale-x: 1.2; -fx-scale-y: 1.2;" />
                                <Spinner fx:id="spaSpinner" prefWidth="70" prefHeight="34" editable="true" />
                            </HBox>

                        </VBox>
                    </VBox>

                    <VBox spacing="18.0" prefWidth="300.0"
                          style="-fx-background-color: rgba(255,255,255,0.025);
                                 -fx-border-color: rgba(200,168,75,0.22); -fx-border-width: 1;
                                 -fx-background-radius: 14; -fx-border-radius: 14;
                                 -fx-padding: 30 28;">

                        <Label text="PRICE PREVIEW"
                               style="-fx-text-fill: #c8a84b; -fx-font-size: 10px; -fx-letter-spacing: 3px; -fx-font-weight: bold;" />

                        <Region prefHeight="4.0" />

                        <VBox spacing="10.0"
                              style="-fx-background-color: #0f0f1a; -fx-background-radius: 10;
                                     -fx-border-color: rgba(200,168,75,0.12); -fx-border-width: 1; -fx-border-radius: 10;
                                     -fx-padding: 18;">
                            <HBox>
                                <Label text="Add-ons Subtotal"
                                       style="-fx-text-fill: #7a6a4a; -fx-font-size: 13px;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="addonsTotalLabel" text="0.00"
                                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            </HBox>
                        </VBox>

                        <Label text="Shown prices are for add-ons only. Full breakdown appears on the summary page."
                               style="-fx-text-fill: #3a3028; -fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>

                        <Region VBox.vgrow="ALWAYS" />

                        <Separator style="-fx-background-color: rgba(200,168,75,0.15);" />

                        <Region prefHeight="4.0" />

                        <Button onAction="#goToLoyalty" text="CONFIRM SERVICES"
                                style="-fx-background-color: #c8a84b; -fx-text-fill: #08080f;
                                       -fx-font-weight: bold; -fx-pref-height: 50; -fx-pref-width: 248;
                                       -fx-cursor: hand; -fx-background-radius: 8;
                                       -fx-font-size: 13px; -fx-letter-spacing: 1px;" />

                        <Button onAction="#goToRoomSelection" text="Back to Rooms"
                                style="-fx-background-color: transparent; -fx-text-fill: #7a6a4a;
                                       -fx-font-size: 12px; -fx-cursor: hand; -fx-underline: true;" />
                    </VBox>

                </HBox>

            </VBox>
        </content>
    </ScrollPane>

    <Button onAction="#showRules" text="RULES AND POLICIES"
            AnchorPane.rightAnchor="38.0" AnchorPane.topAnchor="38.0"
            style="-fx-background-color: transparent; -fx-text-fill: #c8a84b;
                   -fx-border-color: rgba(200,168,75,0.5); -fx-border-width: 1;
                   -fx-cursor: hand; -fx-padding: 9 16;
                   -fx-background-radius: 6; -fx-border-radius: 6;
                   -fx-font-size: 11px; -fx-letter-spacing: 1px;" />

</AnchorPane>