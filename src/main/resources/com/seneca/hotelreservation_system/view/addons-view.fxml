<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.AddOnsController">

    <VBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <Label text="ENHANCE YOUR STAY" style="-fx-text-fill: #d4af37; -fx-font-size: 32px; -fx-font-weight: bold;" />

        <VBox spacing="20.0" style="-fx-background-color: #0a0a0a; -fx-padding: 30; -fx-border-color: #44403c; -fx-border-radius: 10;" prefWidth="500">
            <Label text="SELECT AMENITIES" style="-fx-text-fill: #d4af37; -fx-font-weight: bold;" />

            <!-- Add-ons with fx:id for controller access -->
            <CheckBox fx:id="wifiCheck" text="High-Speed WiFi ($9.99 / night)" style="-fx-text-fill: white;" />
            <CheckBox fx:id="spaCheck" text="Spa &amp; Wellness Access ($49.99 / night)" style="-fx-text-fill: white;" />
            <CheckBox fx:id="shuttleCheck" text="Airport Shuttle ($35.00 / trip)" style="-fx-text-fill: white;" />
            <CheckBox fx:id="breakfastCheck" text="Daily Breakfast Package ($24.99 / night)" style="-fx-text-fill: white;" />

            <!-- Quantity spinners -->
            <HBox spacing="10">
                <Label text="WiFi Quantity:" style="-fx-text-fill: #a8a29e;" />
                <Spinner fx:id="wifiSpinner" prefWidth="80" editable="true" />
            </HBox>
            <HBox spacing="10">
                <Label text="Breakfast Quantity:" style="-fx-text-fill: #a8a29e;" />
                <Spinner fx:id="breakfastSpinner" prefWidth="80" editable="true" />
            </HBox>
            <HBox spacing="10">
                <Label text="Shuttle Quantity:" style="-fx-text-fill: #a8a29e;" />
                <Spinner fx:id="shuttleSpinner" prefWidth="80" editable="true" />
            </HBox>
            <HBox spacing="10">
                <Label text="Spa Quantity:" style="-fx-text-fill: #a8a29e;" />
                <Spinner fx:id="spaSpinner" prefWidth="80" editable="true" />
            </HBox>
        </VBox>

        <!-- Buttons only -->
        <HBox alignment="CENTER" spacing="20">
            <Button onAction="#goToLoyalty" text="CONFIRM &amp; FINISH"
                    style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-height: 55; -fx-pref-width: 200; -fx-cursor: hand; -fx-background-radius: 5;" />
            <Button onAction="#goToRoomSelection" text="BACK TO DETAILS"
                    style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-pref-height: 55; -fx-pref-width: 200; -fx-cursor: hand; -fx-border-radius: 5;" />
        </HBox>

    </VBox>

    <Button text="TEST WIFI" onAction="#testWiFi" style="-fx-background-color: red; -fx-text-fill: white;" />
    <Button onAction="#showRules" text="RULES &amp; POLICIES"
            AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0"
            style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-cursor: hand;" />

</AnchorPane>