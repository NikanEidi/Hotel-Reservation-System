<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #020617;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seneca.hotelreservation_system.controller.SearchController">

    <HBox alignment="CENTER" spacing="10" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="30.0">
        <Label text="①" style="-fx-text-fill: #d4af37; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label text="──" style="-fx-text-fill: #d4af37;"/>
        <Label text=" ② " style="-fx-text-fill: #d4af37; -fx-font-size: 18px; -fx-font-weight: bold; -fx-border-color: #d4af37; -fx-border-radius: 50; -fx-padding: 5;"/>
        <Label text="── ③ ── ④ ── ⑤ ── ⑥ ── ⑦" style="-fx-text-fill: #44403c; -fx-font-size: 16px;"/>
    </HBox>

    <VBox alignment="CENTER" spacing="40.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="15.0">
            <Label text="FIND YOUR STAY" style="-fx-text-fill: #d4af37; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-letter-spacing: 5px;" />
            <Label text="Step 2: Enter your travel details" style="-fx-text-fill: #78716c; -fx-font-size: 16px; -fx-text-transform: uppercase; -fx-letter-spacing: 2px;" />
        </VBox>

        <VBox alignment="CENTER" spacing="20.0">

            <!-- Error Label -->
            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 14px; -fx-font-weight: bold;" visible="false" managed="false" />

            <HBox alignment="CENTER" maxWidth="1100.0" spacing="25.0" style="-fx-background-color: #0a0a0a; -fx-padding: 25; -fx-border-color: #d4af37; -fx-border-width: 1; -fx-background-radius: 5; -fx-border-radius: 5;">
                <effect><DropShadow color="#d4af371a" radius="15.0" /></effect>

                <!-- Date Pickers - FIXED IDs -->
                <DatePicker fx:id="checkInDatePicker" promptText="Check-in Date" style="-fx-pref-width: 220; -fx-font-size: 14px;" />
                <DatePicker fx:id="checkOutDatePicker" promptText="Check-out Date" style="-fx-pref-width: 220; -fx-font-size: 14px;" />

                <!-- Adults Counter -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Adults" style="-fx-text-fill: #d4af37; -fx-font-size: 12px;"/>
                    <HBox alignment="CENTER" spacing="10">
                        <Button text="-" onAction="#decreaseAdults" style="-fx-background-color: #333; -fx-text-fill: white; -fx-pref-width: 35; -fx-pref-height: 35; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Label fx:id="adultCountLabel" text="2" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-pref-width: 40; -fx-alignment: center;"/>
                        <Button text="+" onAction="#increaseAdults" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-pref-width: 35; -fx-pref-height: 35; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Children Counter -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Children" style="-fx-text-fill: #d4af37; -fx-font-size: 12px;"/>
                    <HBox alignment="CENTER" spacing="10">
                        <Button text="-" onAction="#decreaseChildren" style="-fx-background-color: #333; -fx-text-fill: white; -fx-pref-width: 35; -fx-pref-height: 35; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Label fx:id="childCountLabel" text="1" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-pref-width: 40; -fx-alignment: center;"/>
                        <Button text="+" onAction="#increaseChildren" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-pref-width: 35; -fx-pref-height: 35; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <Button onAction="#goToRoomSelection" text="CONTINUE" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 45; -fx-cursor: hand;" />
            </HBox>

            <Label text="* Maximum occupancy: 4 guests for Double suites, 2 for Deluxe/Single suites."
                   style="-fx-text-fill: #44403c; -fx-font-size: 12px; -fx-font-style: italic;" />
        </VBox>

        <!-- GUEST DETAILS SECTION - ADDED -->
        <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #0a0a0a; -fx-padding: 25; -fx-border-color: #d4af37; -fx-border-width: 1; -fx-background-radius: 5; -fx-border-radius: 5; max-width: 800;">
            <Label text="GUEST DETAILS" style="-fx-text-fill: #d4af37; -fx-font-size: 20px; -fx-font-weight: bold; -fx-letter-spacing: 2px;" />

            <GridPane hgap="20" vgap="15" alignment="CENTER">
                <Label text="Full Name *" style="-fx-text-fill: #d4af37;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="fullNameField" promptText="John Smith" style="-fx-pref-width: 300; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Email *" style="-fx-text-fill: #d4af37;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="emailField" promptText="john.smith@email.com" style="-fx-pref-width: 300; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Phone *" style="-fx-text-fill: #d4af37;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="phoneField" promptText="(555) 123-4567" style="-fx-pref-width: 300; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>
        </VBox>

        <Button onAction="#goToWelcome" text="RETURN TO MAIN MENU" style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
    </VBox>

    <Button onAction="#showRules" text="RULES &amp; POLICIES" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0" style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-border-width: 0.5; -fx-cursor: hand; -fx-padding: 10 20;" />

</AnchorPane>